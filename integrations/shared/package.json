{
  "name": "@tooltify/integration-shared",
  "version": "0.2.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./source-transformers/react": {
      "types": "./dist/source-transformers/react.d.ts",
      "import": "./dist/source-transformers/react.js",
      "require": "./dist/source-transformers/react.js",
      "default": "./dist/source-transformers/react.js"
    },
    "./source-transformers/vue": {
      "types": "./dist/source-transformers/vue.d.ts",
      "import": "./dist/source-transformers/vue.js",
      "require": "./dist/source-transformers/vue.js",
      "default": "./dist/source-transformers/vue.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "*",
    "@vue/compiler-core": "*"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@vue/compiler-core": {
      "optional": true
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "tooltify",
    "integration",
    "shared"
  ],
  "author": "Franco Werner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/franwerner/tooltify.git",
    "directory": "integrations/shared"
  }
}