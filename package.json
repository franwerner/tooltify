{
  "name": "tooltify",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:core && npm run build:integrations",
    "build:core": "npm run build --workspace=core",
    "build:integrations": "npm run build --workspace=@tooltify/integration-rspack"
  },
  "keywords": [
    "devtools",
    "cli",
    "tools",
    "typescript"
  ],
  "author": "Franco Werner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/franwerner/tooltify"
  },
  "workspaces": [
    "core",
    "integrations/*",
    "playground"
  ],
  "overrides": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}