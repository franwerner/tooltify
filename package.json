{
  "name": "chad-tools",
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "build": "npm run build:client && npm run build:lib",
    "build:client": "npm run build -w core/client",
    "build:lib": "tsup",
    "dev:client": "npm run dev -w core/client"
  },
  "keywords": [
    "devtools",
    "cli",
    "tools",
    "typescript"
  ],
  "author": "Franco Werner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/franwerner/chad-tools"
  },
  "exports": {
    "./core": {
      "import": "./dist/core.js",
      "types": "./dist/core.d.ts"
    },
    "./rspack": {
      "import": "./dist/rspack.js",
      "types": "./dist/rspack.d.ts"
    }
  },
  "files": [
    "dist",
    "core/client/dist"
  ],
  "workspaces": [
    "core/client",
    "core/server",
    "integrations",
    "playground"
  ],
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "cors": "^2.8.6"
  }
}