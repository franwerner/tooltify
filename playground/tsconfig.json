{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
