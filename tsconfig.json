{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "typeRoots": ["node_modules/@types"]
  },
  "include": [
    "core/server/**/*.ts",
    "integrations/**/*.ts"
  ],
  "exclude": [
    "core/client",
    "playground",
    "node_modules",
    "dist"
  ]
}