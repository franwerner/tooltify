{
  "name": "@tooltify/core",
  "version": "0.2.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:lib && npm run build:client",
    "build:lib": "tsup",
    "build:agent": "tsup --entry.agent ./agent/index.ts --no-dts --no-clean",
    "build:cli": "tsup --entry.cli ./cli/index.ts --no-dts --no-clean",
    "build:client": "vite build --config ./client/vite.config.ts",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "tooltify": "./dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@clack/prompts": "1.0.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "object-hash": "^3.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "monaco-editor": "^0.53.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-components": "^6.3.11",
    "tailwindcss": "^3.4.19",
    "vite": "^6.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/franwerner/tooltify.git",
    "directory": "core/"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "devtools",
    "cli",
    "tools",
    "typescript"
  ],
  "author": "Franco Werner",
  "license": "MIT",
  "description": ""
}
