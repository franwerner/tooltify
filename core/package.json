{
  "name": "@tooltify/core",
  "version": "0.1.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:client && npm run build:lib",
    "build:lib": "tsup",
    "build:agent": "tsup --entry.agent ./agent/index.ts --no-dts --no-clean",
    "build:cli": "tsup --entry.cli ./cli/index.ts --no-dts --no-clean",
    "build:client": "vite build --config ./client/vite.config.ts",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "tooltify": "./dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "jsonwebtoken": "^9.0.3",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-components": "^6.3.11",
    "vite": "^6.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/franwerner/tooltify/tree/master/core"
  },
  "files": [
    "dist",
    "client/dist"
  ],
  "keywords": [
    "devtools",
    "cli",
    "tools",
    "typescript"
  ],
  "author": "Franco Werner",
  "license": "MIT",
  "description": ""
}
